{
  "name": "hermes-desktop",
  "version": "0.1.0",
  "description": "Hermes Desktop Overlay — Professional terminal-like experience for macOS/iOS",
  "type": "module",
  "main": "dist-electron/main/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:all": "npm run build:main && npm run build",
    "postbuild:main": "node scripts/postbuild-main.cjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@hookform/resolvers": "^5.0.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "~18.3.23",
    "@types/react-dom": "~18.3.5",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
